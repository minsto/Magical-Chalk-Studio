<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.magicalchalkstudion.magicalchalkstudio.HelloController"
            styleClass="fusion-app">

    <top>
        <VBox spacing="8.0" BorderPane.alignment="CENTER" styleClass="fusion-toolbar">
            <padding>
                <Insets top="8.0" right="8.0" bottom="8.0" left="8.0"/>
            </padding>

            <FlowPane hgap="6.0" vgap="6.0">
                <Button text="Selection" onAction="#onSelectTool"/>
                <Button text="Line" onAction="#onLineTool"/>
                <Button text="1x1" onAction="#onBlock1x1Tool"/>
                <Button text="2x1" onAction="#onBlock2x1Tool"/>
                <Button text="2x2" onAction="#onBlock2x2Tool"/>
                <Button text="Brush 3x3" onAction="#onBrush3x3Tool"/>
                <Button text="Eraser" onAction="#onEraserTool"/>
                <Button text="Fill Rect" onAction="#onFillRectTool"/>
                <Button text="Wall Rect" onAction="#onWallRectTool"/>
                <Button text="Fill Circle" onAction="#onFillCircleTool"/>
                <Button text="Wall Circle" onAction="#onWallCircleTool"/>
                <Button text="Fill Ellipse" onAction="#onFillEllipseTool"/>
                <Button text="Wall Ellipse" onAction="#onWallEllipseTool"/>
                <Button text="Zone Select" onAction="#onZoneSelectTool"/>

                <Separator orientation="VERTICAL"/>

                <Button text="Annuler" onAction="#onUndo"/>
                <Button text="Refaire" onAction="#onRedo"/>
                <Button text="Copier" onAction="#onCopySelection"/>
                <Button text="Appliquer" onAction="#onApplyProperties"/>
                <Button text="Supprimer" onAction="#onDeleteSelected"/>
                <Button text="Nouvelle creation" onAction="#onNewScene"/>

                <Separator orientation="VERTICAL"/>

                <Button text="Rotation +" onAction="#onRotateSelected"/>
                <Button text="Rotation -" onAction="#onRotateSelectedMinus90"/>
                <Button text="Axe X" onAction="#onSetAxisX"/>
                <Button text="Axe Y" onAction="#onSetAxisY"/>
                <Button text="Axe Z" onAction="#onSetAxisZ"/>
            </FlowPane>

            <FlowPane hgap="6.0" vgap="6.0">
                <Label text="Scene"/>
                <TextField fx:id="sceneNameField" prefWidth="180.0"/>

                <Separator orientation="VERTICAL"/>

                <Label text="X"/>
                <TextField fx:id="xField" prefWidth="60.0"/>
                <Label text="Y"/>
                <TextField fx:id="yField" prefWidth="60.0"/>
                <Label text="W"/>
                <TextField fx:id="widthField" prefWidth="60.0"/>
                <Label text="H"/>
                <TextField fx:id="heightField" prefWidth="60.0"/>

                <Separator orientation="VERTICAL"/>

                <Label text="Block"/>
                <TextField fx:id="blockIdField" prefWidth="220.0"/>
                <Label text="State"/>
                <TextField fx:id="stateField" prefWidth="260.0"/>
                <ColorPicker fx:id="colorPicker"/>
                <CheckBox fx:id="snapCheckBox" text="Snap" selected="true"/>
                <Label text="Taille"/>
                <TextField fx:id="canvasWidthField" prefWidth="110.0" promptText="L"/>
                <Label text="×"/>
                <TextField fx:id="canvasHeightField" prefWidth="110.0" promptText="H"/>
                <Button text="Appliquer taille" onAction="#onApplyCanvasSize"/>
            </FlowPane>

            <FlowPane hgap="6.0" vgap="6.0">
                <Button text="Save Legacy" onAction="#onSaveLegacy"/>
                <Button text="Save Compact" onAction="#onSaveCompact"/>
                <Button text="Save Wrapper" onAction="#onSaveWrapper"/>
                <Button text="Load Legacy" onAction="#onLoadLegacy"/>
            </FlowPane>
        </VBox>
    </top>

    <center>
        <ScrollPane fx:id="scrollPane" fitToHeight="false" fitToWidth="false" pannable="true"
                    styleClass="fusion-canvas-wrap">
            <content>
                <Pane fx:id="canvasPane"/>
            </content>
        </ScrollPane>
    </center>

    <right>
        <VBox spacing="8.0" prefWidth="320.0" BorderPane.alignment="CENTER" styleClass="fusion-side-panel">
            <padding>
                <Insets top="8.0" right="8.0" bottom="8.0" left="8.0"/>
            </padding>

            <TitledPane text="Calques" expanded="true" collapsible="true">
                <VBox spacing="8.0">
                    <padding>
                        <Insets top="8.0" right="8.0" bottom="8.0" left="8.0"/>
                    </padding>
                    <Label text="Calque actif (0–255) : utilisez les flèches ou les boutons pour changer de calque."/>
                    <HBox spacing="8.0">
                        <Button text="Calque +" prefWidth="120.0" onAction="#onLayerUp"/>
                        <Button text="Calque -" prefWidth="120.0" onAction="#onLayerDown"/>
                    </HBox>
                </VBox>
            </TitledPane>

            <TitledPane text="Palette blocs" expanded="true" collapsible="true" VBox.vgrow="ALWAYS">
                <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets top="8.0" right="8.0" bottom="8.0" left="8.0"/>
                    </padding>
                    <TextField fx:id="searchField" promptText="Rechercher un bloc..."/>
                    <ListView fx:id="blockList" VBox.vgrow="ALWAYS"/>
                    <Label text="Direction (aperçu)"/>
                    <Label fx:id="directionPreviewLabel" text="-"/>
                </VBox>
            </TitledPane>

            <Label fx:id="welcomeText" visible="false" managed="false"/>
        </VBox>
    </right>

    <bottom>
        <HBox spacing="20.0" BorderPane.alignment="CENTER_LEFT" styleClass="fusion-status-bar">
            <padding>
                <Insets top="8.0" right="8.0" bottom="8.0" left="8.0"/>
            </padding>
            <Label fx:id="statusLabel" text="Statut : pret"/>
            <Label fx:id="layerLabel" text="Layer : 0"/>
            <Button text="+" prefWidth="36.0" minWidth="36.0" onAction="#onLayerUp"/>
            <Button text="-" prefWidth="36.0" minWidth="36.0" onAction="#onLayerDown"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <HBox spacing="8.0" alignment="CENTER_RIGHT">
                <Button text="−" prefWidth="36.0" minWidth="36.0" onAction="#onZoomOut"/>
                <Slider fx:id="zoomSlider" min="0.01" max="1.0" value="1.0" prefWidth="200.0" blockIncrement="0.05"/>
                <Button text="+" prefWidth="36.0" minWidth="36.0" onAction="#onZoomIn"/>
                <Label fx:id="zoomLabel" text="Zoom : 100%"/>
            </HBox>
        </HBox>
    </bottom>

</BorderPane>
